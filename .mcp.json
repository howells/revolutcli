{
  "$schema": "https://modelcontextprotocol.io/schemas/0.1/mcp.json",
  "mcpServers": {
    "revolut": {
      "command": "revolutcli-mcp",
      "args": [],
      "env": {
        "REVOLUT_CLIENT_ID": "${REVOLUT_CLIENT_ID}",
        "REVOLUT_PRIVATE_KEY_PATH": "${REVOLUT_PRIVATE_KEY_PATH}"
